# Copy to .env and fill in. `.env` is gitignored — keep it that way.

# GitHub personal access token. braggraphs only READS, so use the least-
# privileged token that works: for public repos, a classic token with NO
# scopes at all (or a fine-grained token with "Public repositories
# read-only"). Private repos need `repo` scope / an explicit fine-grained
# grant. Required if the `github:` block is present in config.yml.
GITHUB_PAT=

# Password for the /admin dashboard. Required if admin is enabled in config.yml.
BRAGGRAPHS_ADMIN_PASSWORD=

# Path to a Google Cloud service-account JSON key with Viewer access on your
# GA4 properties. Only required if the `ga4:` block is present in config.yml.
# In Docker, mount the key file and point this at the in-container path.
GOOGLE_APPLICATION_CREDENTIALS=

# Cloudflare API token with the account-level "Account Analytics: Read"
# permission (dash.cloudflare.com/profile/api-tokens → Create → Custom).
# Only required if the `cloudflare:` block is present in config.yml.
CLOUDFLARE_API_TOKEN=

# Optional: Flask session secret. If unset, one is generated and persisted
# into the data directory on first boot.
# BRAGGRAPHS_SECRET_KEY=

# Optional overrides (defaults shown)
# BRAGGRAPHS_CONFIG=config.yml
# BRAGGRAPHS_DATA_DIR=data
